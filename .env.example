# AWS Credentials for Promtail CloudWatch Access
# Create an IAM user with CloudWatch Logs read permissions
# and generate access keys
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Grafana Admin Credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_this_password

# Notes:
# 1. Copy this file to .env and fill in your actual credentials
# 2. Never commit .env file to git
# 3. Make sure to add .env to .gitignore
